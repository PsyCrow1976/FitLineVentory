# Copy to .env and adjust for your environment.
# Unraid example: http://192.168.1.130:8080

# --- Published port (nginx) ---
HTTP_PORT=8080

# --- PostgreSQL ---
POSTGRES_USER=fitlineventory
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=fitlineventory

# --- API ---
DATABASE_URL=postgresql+psycopg://fitlineventory:change-me-to-a-strong-password@db:5432/fitlineventory
JWT_SECRET=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin-password
CORS_ORIGINS=http://localhost:8080,http://192.168.1.130:8080
REORDER_LOOKBACK_DAYS=30

# --- Unraid volume paths (optional overrides) ---
# POSTGRES_DATA_PATH=./data/postgres